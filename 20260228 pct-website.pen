            0,
            320,
            80,
            320
          ],
          "children": [
            {
              "type": "frame",
              "id": "cynQg",
              "name": "ppSec1",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "uQRE7",
                  "name": "ppS1h",
                  "fill": "$text-primary",
                  "content": "1. Information We Collect",
                  "fontFamily": "Source Serif 4",
                  "fontSize": 24,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "OvwBQ",
                  "name": "ppS1p",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "When you make a donation, we collect your name, email address, and an optional message. Payment information is processed directly by Stripe and is never stored on our servers. We also collect anonymous usage data through standard web analytics to understand how visitors interact with the site.",
                  "lineHeight": 1.8,
                  "fontFamily": "Source Serif 4",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "6jbPU",
              "name": "ppSec2",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "M48pn",
                  "name": "ppS2h",
                  "fill": "$text-primary",
                  "content": "2. How We Use Your Information",
                  "fontFamily": "Source Serif 4",
                  "fontSize": 24,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "vsd1N",
                  "name": "ppS2p",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Your information is used solely to process donations, display your name and message on the donor wall (unless you choose to remain anonymous), and send occasional updates about Paul's trail progress and the impact of your donation. We will never sell, rent, or share your personal information with third parties for marketing purposes.",
                  "lineHeight": 1.8,
                  "fontFamily": "Source Serif 4",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "yh7Ah",
              "name": "ppSec3",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "YvaFw",
                  "name": "ppS3h",
                  "fill": "$text-primary",
                  "content": "3. Cookies and Tracking",
                  "fontFamily": "Source Serif 4",
                  "fontSize": 24,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "jvJHM",
                  "name": "ppS3p",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "This website uses essential cookies required for basic functionality. We may use analytics tools to understand site traffic and improve the user experience. These tools collect anonymized data such as pages visited, time on site, and browser type. No personally identifiable information is collected through analytics.",
                  "lineHeight": 1.8,
                  "fontFamily": "Source Serif 4",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "Fzo4c",
              "name": "ppSec4",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "URQy6",
                  "name": "ppS4h",
                  "fill": "$text-primary",
                  "content": "4. Data Security",
                  "fontFamily": "Source Serif 4",
                  "fontSize": 24,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "R3PFt",
                  "name": "ppS4p",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "We take reasonable measures to protect your personal information. All donation transactions are encrypted using SSL/TLS technology through Stripe. However, no method of transmission over the Internet is 100% secure, and we cannot guarantee absolute security.",
                  "lineHeight": 1.8,
                  "fontFamily": "Source Serif 4",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "hxtZB",
              "name": "ppSec5",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "pOMi7",
                  "name": "ppS5h",
                  "fill": "$text-primary",
                  "content": "5. Your Rights",
                  "fontFamily": "Source Serif 4",
                  "fontSize": 24,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "Hdebp",
                  "name": "ppS5p",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "You have the right to request access to, correction of, or deletion of your personal data at any time. If you wish to have your donor information removed from the website or our records, please contact us and we will process your request promptly.",
                  "lineHeight": 1.8,
                  "fontFamily": "Source Serif 4",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "bd3Lc",
              "name": "ppSec6",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "Rbb3O",
                  "name": "ppS6h",
                  "fill": "$text-primary",
                  "content": "6. Third-Party Services",
                  "fontFamily": "Source Serif 4",
                  "fontSize": 24,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "Q6Da6",
                  "name": "ppS6p",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "This website uses Stripe for payment processing and OpenStreetMap for trail mapping. These services have their own privacy policies governing how they handle your data. We encourage you to review their respective policies.",
                  "lineHeight": 1.8,
                  "fontFamily": "Source Serif 4",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "6n5jD",
              "name": "ppSec7",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "bTL4c",
                  "name": "ppS7h",
                  "fill": "$text-primary",
                  "content": "7. Contact",
                  "fontFamily": "Source Serif 4",
                  "fontSize": 24,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "MnXaE",
                  "name": "ppS7p",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "If you have any questions about this Privacy Policy or wish to exercise your data rights, please reach out via the contact information provided on the website or through our social media channels.",
                  "lineHeight": 1.8,
                  "fontFamily": "Source Serif 4",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
